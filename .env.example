# Production environment variables for NorthPark Produce El Cajon
# Copy this file to .env.local and fill in real values.

# Web3Forms API key — used for catering inquiry form and weekly ad email signup.
# 1. Sign up free at https://web3forms.com
# 2. Verify your email (northparkproduce@yahoo.com)
# 3. Copy your access key from the dashboard
# 4. Paste below — both forms route submissions to your email automatically
NEXT_PUBLIC_WEB3FORMS_KEY=

# Optional: override the canonical site URL (defaults to Vercel auto domain)
NEXT_PUBLIC_SITE_URL=https://northpark-produce-el-cajon.vercel.app
